# ── Vision agent (ONE of these is required) ───────────────────────────────────
# Option A: Groq — free tier, fast, great vision quality
#   Get key: https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Text agents via OpenRouter (required) ─────────────────────────────────────
# Free-tier models are used by default — no billing needed unless you opt in.
#   Get key: https://openrouter.ai/keys
# If GROQ_API_KEY is not set, the vision step also falls back to OpenRouter
# (google/gemini-2.0-flash-exp:free) — so OPENROUTER_API_KEY alone is enough.
OPENROUTER_API_KEY=sk-or-...

# ── Auth + usage tracking (Supabase free tier) ────────────────────────────────
#   Get: https://supabase.com → new project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Add your production frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Rate limiting (optional — Upstash free tier) ──────────────────────────────
# If these are not set, rate limiting is skipped (fine for low-traffic deploys).
#   Get: https://console.upstash.com → create Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Payments (optional — LemonSqueezy) ────────────────────────────────────────
LEMON_WEBHOOK_SECRET=your_lemon_signing_secret

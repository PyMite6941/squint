# Text agents — CrewAI pipeline (OpenRouter free models, required)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Vision agent — Groq (optional, improves vision quality)
# Falls back to OpenRouter (google/gemini-2.0-flash-exp:free) if not set
# Get key: https://console.groq.com
GROQ_API_KEY=gsk_...

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://squint-ten.vercel.app
